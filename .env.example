# Quarkus (run from project root). DB and Keycloak on localhost when using compose.
DB_URL=jdbc:postgresql://localhost:5432/livemenu
DB_USER=
DB_PASSWORD=

KEYCLOAK_URL=http://localhost:8180
OIDC_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=

GOOGLE_APPLICATION_CREDENTIALS=
GCP_STORAGE_BUCKET_NAME=

# Rate limiting (RNF04). Optional.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Analytics: salt for IP hashing (anonimización). Set in production.
# ANALYTICS_IP_HASH_SALT=your-secret-salt

