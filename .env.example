# Copy this file to .env and set real values. Never commit .env.
# For compose: copy to compose/.env. For Quarkus dev: use project root .env or export vars.

# Postgres (compose + init script)
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# App DB user (init script + pgbouncer; same as DB_USER/DB_PASSWORD for Quarkus)
DB_PASSWORD=

# Keycloak DB user (init script + pgbouncer + Keycloak container)
KC_DB_PASSWORD=

# Pgbouncer
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20
DB_PORT=5432
PGBOUNCER_PORT=6432

# Keycloak server (compose)
KC_DB_URL=jdbc:postgresql://pgbouncer:6432/keycloak
KC_DB_USERNAME=keycloak
KC_HOSTNAME=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# Client secrets: set per environment; used in realm import and by the app
OIDC_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Quarkus datasource (when running the app)
DB_URL=jdbc:postgresql://localhost:6432/livemenu
DB_USER=livemenu
