# Postgres (compose)
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PgBouncer
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20
DB_PORT=5432
PGBOUNCER_PORT=6432

# Keycloak DB (must match init + userlist: keycloak/keycloak123)
KC_DB_URL=jdbc:postgresql://pgbouncer:6432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak123

# Keycloak admin console
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_HOSTNAME=localhost

# App DB user (init script + pgbouncer; same user as Quarkus uses)
DB_PASSWORD=livemenu

# Client secrets (realm import + Quarkus). Must match realm client config.
OIDC_CLIENT_SECRET=livemenu-backend-dev-secret
KEYCLOAK_ADMIN_CLIENT_SECRET=backend-admin-dev-secret
