# Postgres (compose)
POSTGRES_DB=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=

DB_PORT=5432

# Keycloak DB (must match init + userlist: keycloak/keycloak123)
KC_DB_URL=jdbc:postgresql://pgbouncer:5432/keycloak
KC_DB_USERNAME=
KC_DB_PASSWORD=

# Keycloak admin console
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KC_HOSTNAME=localhost

# App DB user (init script + pgbouncer; same user as Quarkus uses)
DB_PASSWORD=

# Client secrets (realm import + Quarkus). Must match realm client config.
OIDC_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_SECRET=

# LiveMenu app (when running in Docker Compose)
KEYCLOAK_REALM=
OIDC_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_ID=
PUBLIC_BASE_URL=
HIBERNATE_SCHEMA_STRATEGY=

# GCP Storage (optional: for image upload). Path to service account JSON on host; inside container it is /app/config/gcp-credentials.json
GCP_CREDENTIALS_FILE=./gcp-credentials.json
GCP_STORAGE_BUCKET_NAME=
