# ============================================================
# LiveMenu — variables de entorno para desarrollo local
# cp .env.example .env  y ajusta los valores antes de usar.
# NUNCA commitees el archivo .env real.
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DB_PORT=5432

# ─── Base de datos de la aplicación ──────────────────────────
DB_PASSWORD=change_me

# ─── Base de datos de Keycloak ───────────────────────────────
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change_me

# ─── Keycloak admin ──────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me
KC_HOSTNAME=localhost

# ─── Secrets OIDC (deben coincidir con realm/livemenu-realm.json) ──
OIDC_CLIENT_SECRET=change_me
KEYCLOAK_ADMIN_CLIENT_SECRET=change_me

# ─── URL de Keycloak (para el servicio livemenu) ─────────────
KEYCLOAK_URL=http://keycloak:8080

# ─── Estrategia de schema Hibernate ──────────────────────────
# update      → sincroniza sin borrar datos (recomendado para dev)
# validate    → solo valida, falla si hay diferencias (producción con Flyway)
# drop-and-create → borra y recrea todo (solo dev desde cero)
HIBERNATE_SCHEMA_STRATEGY=update

# ─── GCP Storage (opcional) ──────────────────────────────────
# Ruta al JSON de service account en el host (relativa al directorio compose/)
GCP_CREDENTIALS_FILE=./gcp-credentials.json
GCP_STORAGE_BUCKET_NAME=

# ─── HTTPS (deshabilitado por defecto) ───────────────────────
HTTPS_ENABLED=false
HTTPS_PORT=8443
HTTPS_KEYSTORE_FILE=/app/config/keystore.p12
HTTPS_KEYSTORE_PASSWORD=changeit
HTTPS_INSECURE_REQUESTS=enabled

# ─── Puertos expuestos en el host ────────────────────────────
LIVEMENU_PORT=8081
LIVEMENU_HTTPS_PORT=8444
