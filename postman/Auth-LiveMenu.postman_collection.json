{
  "info": {
    "name": "Auth - LiveMenu",
    "description": "Auth endpoints: register, login, current user, logout.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "access_token", "value": "" }
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpass123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/register",
        "description": "Creates a new user. Returns 201 on success, 400 if email already exists."
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    if (json.access_token) {",
              "        pm.collectionVariables.set('access_token', json.access_token);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpass123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login",
        "description": "Returns access_token, refresh_token, expires_in. Saves access_token to collection variable for protected requests."
      }
    },
    {
      "name": "Get current user",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/auth/user",
        "description": "Protected endpoint. Requires valid JWT in Authorization header. Run Login first."
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/auth/logout",
        "description": "Revokes the session. Optional: send SESSION cookie if using cookie-based session."
      }
    }
  ]
}
