{
  "info": {
    "name": "LiveMenu API",
    "description": "Complete API collection for LiveMenu: Authentication, Restaurant Management (CU-02), Categories (CU-03), Dishes (CU-04), and Image Upload (CU-05)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string", "description": "Refresh token for token renewal" },
    { "key": "restaurantId", "value": "", "type": "string", "description": "UUID of a restaurant (set after creating one)" },
    { "key": "categoryId", "value": "", "type": "string", "description": "UUID of a category (set after creating one)" },
    { "key": "dishId", "value": "", "type": "string", "description": "UUID of a dish (set after creating one)" },
    { "key": "slug", "value": "my-restaurant", "type": "string", "description": "Restaurant slug for public menu endpoints" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Creates a new user. Returns 201 on success, 400 if email already exists."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.access_token) {",
                  "        pm.collectionVariables.set('access_token', json.access_token);",
                  "        console.log('Access token saved to collection variable');",
                  "    }",
                  "    if (json.refresh_token) {",
                  "        pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "        console.log('Refresh token saved to collection variable');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Returns access_token, refresh_token, expires_in. Automatically saves access_token to collection variable for protected requests."
          }
        },
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "user"]
            },
            "description": "Protected endpoint. Requires valid JWT in Authorization header. Run Login first."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Refreshes the access token using a refresh token. Returns new access_token and refresh_token. Automatically updates collection variables.",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    const json = pm.response.json();",
                    "    if (json.access_token) {",
                    "        pm.collectionVariables.set('access_token', json.access_token);",
                    "        console.log('Access token refreshed and saved');",
                    "    }",
                    "    if (json.refresh_token) {",
                    "        pm.collectionVariables.set('refresh_token', json.refresh_token);",
                    "        console.log('Refresh token updated');",
                    "    }",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Revokes the session. Optional: send SESSION cookie if using cookie-based session."
          }
        }
      ],
      "description": "Authentication endpoints: register, login, logout, and user info."
    },
    {
      "name": "Restaurant Management (CU-02)",
      "item": [
        {
          "name": "List Restaurants",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants"]
            },
            "description": "Lists all restaurants for the current user. Returns an array of restaurants. Requires authentication."
          }
        },
        {
          "name": "Get Restaurant by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Gets a specific restaurant by ID. Returns 404 if restaurant not found or doesn't belong to user. Requires authentication."
          }
        },
        {
          "name": "Create Restaurant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Restaurant\",\n  \"description\": \"A great place to eat\",\n  \"logo\": \"https://example.com/logo.png\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main St, City, Country\",\n  \"schedule\": {\n    \"monday\": {\n      \"open\": \"09:00\",\n      \"close\": \"22:00\",\n      \"closed\": false\n    },\n    \"tuesday\": {\n      \"open\": \"09:00\",\n      \"close\": \"22:00\",\n      \"closed\": false\n    },\n    \"wednesday\": {\n      \"open\": \"09:00\",\n      \"close\": \"22:00\",\n      \"closed\": false\n    },\n    \"thursday\": {\n      \"open\": \"09:00\",\n      \"close\": \"22:00\",\n      \"closed\": false\n    },\n    \"friday\": {\n      \"open\": \"09:00\",\n      \"close\": \"23:00\",\n      \"closed\": false\n    },\n    \"saturday\": {\n      \"open\": \"10:00\",\n      \"close\": \"23:00\",\n      \"closed\": false\n    },\n    \"sunday\": {\n      \"open\": \"10:00\",\n      \"close\": \"21:00\",\n      \"closed\": false\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants"]
            },
            "description": "Creates a new restaurant for the current user. Name is required (max 100 chars), description is optional (max 500 chars). Users can have multiple restaurants. Returns 201 on success, 400 if validation fails.\n\n**Tip:** After creating a restaurant, copy its `id` from the response and set it as the `restaurantId` collection variable for easier testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('restaurantId', json.id);",
                  "        console.log('Restaurant ID saved to collection variable:', json.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Restaurant",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Restaurant Name\",\n  \"description\": \"Updated description\",\n  \"logo\": \"https://example.com/new-logo.png\",\n  \"phone\": \"+1234567891\",\n  \"address\": \"456 New St, City, Country\",\n  \"schedule\": {\n    \"monday\": {\n      \"open\": \"10:00\",\n      \"close\": \"21:00\",\n      \"closed\": false\n    },\n    \"tuesday\": {\n      \"open\": \"10:00\",\n      \"close\": \"21:00\",\n      \"closed\": false\n    },\n    \"wednesday\": {\n      \"open\": \"10:00\",\n      \"close\": \"21:00\",\n      \"closed\": false\n    },\n    \"thursday\": {\n      \"open\": \"10:00\",\n      \"close\": \"21:00\",\n      \"closed\": false\n    },\n    \"friday\": {\n      \"open\": \"10:00\",\n      \"close\": \"22:00\",\n      \"closed\": false\n    },\n    \"saturday\": {\n      \"open\": \"11:00\",\n      \"close\": \"22:00\",\n      \"closed\": false\n    },\n    \"sunday\": {\n      \"closed\": true\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Updates a specific restaurant by ID. All fields are optional. If name is updated, slug is automatically regenerated. Returns 404 if restaurant not found or doesn't belong to user."
          }
        },
        {
          "name": "Delete Restaurant",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Deletes a specific restaurant by ID. Returns 204 on success, 404 if restaurant not found or doesn't belong to user."
          }
        }
      ],
      "description": "Restaurant management endpoints (CU-02). Users can have multiple restaurants. All endpoints require authentication via Bearer token."
    },
    {
      "name": "Category Management (CU-03)",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "categories"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Lists all categories for a restaurant, ordered by position. Requires authentication."
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/categories/:categoryId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "categories", ":categoryId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "",
                  "description": "UUID of the restaurant"
                },
                {
                  "key": "categoryId",
                  "value": "",
                  "description": "UUID of the category"
                }
              ]
            },
            "description": "Gets a specific category by ID. Returns 404 if not found. Requires authentication."
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Appetizers\",\n  \"description\": \"Start your meal with our delicious appetizers\",\n  \"position\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "categories"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Creates a new category. Name is required (max 50 chars). Position is optional (auto-calculated if not provided). Returns 201 on success.\n\n**Tip:** After creating a category, copy its `id` from the response and set it as the `categoryId` collection variable for easier testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('categoryId', json.id);",
                  "        console.log('Category ID saved to collection variable:', json.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Category Name\",\n  \"description\": \"Updated description\",\n  \"position\": 2,\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/categories/:categoryId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "categories", ":categoryId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "",
                  "description": "UUID of the restaurant"
                },
                {
                  "key": "categoryId",
                  "value": "",
                  "description": "UUID of the category"
                }
              ]
            },
            "description": "Updates a category. All fields are optional. Returns 404 if not found."
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/categories/:categoryId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "categories", ":categoryId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "",
                  "description": "UUID of the restaurant"
                },
                {
                  "key": "categoryId",
                  "value": "",
                  "description": "UUID of the category"
                }
              ]
            },
            "description": "Deletes a category. Only if it has no dishes. Returns 204 on success, 400 if category has dishes."
          }
        },
        {
          "name": "Reorder Categories",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryIds\": [\n    \"{{categoryId}}\",\n    \"category-uuid-2\",\n    \"category-uuid-3\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/categories/reorder",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "categories", "reorder"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Reorders categories by updating their positions based on the provided order. Returns 204 on success."
          }
        }
      ],
      "description": "Category management endpoints (CU-03). All endpoints require authentication via Bearer token."
    },
    {
      "name": "Dish Management (CU-04)",
      "item": [
        {
          "name": "List Dishes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/dishes?categoryId=&available=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "dishes"],
              "query": [
                {
                  "key": "categoryId",
                  "value": "",
                  "description": "Optional: Filter by category UUID"
                },
                {
                  "key": "available",
                  "value": "",
                  "description": "Optional: Filter by availability (true/false)"
                }
              ],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Lists all dishes for a restaurant. Optional filters: categoryId, available. Requires authentication."
          }
        },
        {
          "name": "Get Dish by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/dishes/:dishId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "dishes", ":dishId"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                },
                {
                  "key": "dishId",
                  "value": "{{dishId}}",
                  "description": "UUID of the dish"
                }
              ]
            },
            "description": "Gets a specific dish by ID. Returns 404 if not found. Requires authentication."
          }
        },
        {
          "name": "Create Dish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"name\": \"Caesar Salad\",\n  \"description\": \"Fresh romaine lettuce with caesar dressing\",\n  \"price\": 12.99,\n  \"offerPrice\": 9.99,\n  \"imageUrl\": \"https://example.com/caesar-salad.jpg\",\n  \"featured\": true,\n  \"tags\": [\"vegetarian\", \"gluten-free\"],\n  \"position\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/dishes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "dishes"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Creates a new dish. categoryId, name, and price are required. Description max 300 chars. offerPrice, featured, tags, and position are optional. Returns 201 on success.\n\n**Tip:** After creating a dish, copy its `id` from the response and set it as the `dishId` collection variable for easier testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('dishId', json.id);",
                  "        console.log('Dish ID saved to collection variable:', json.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Dish with Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}",
                  "type": "text",
                  "description": "UUID of the category (required). Use {{categoryId}} variable or paste a category UUID."
                },
                {
                  "key": "name",
                  "value": "Caesar Salad",
                  "type": "text",
                  "description": "Dish name (required)"
                },
                {
                  "key": "description",
                  "value": "Fresh romaine lettuce with caesar dressing",
                  "type": "text",
                  "description": "Dish description (optional, max 300 chars)"
                },
                {
                  "key": "price",
                  "value": "12.99",
                  "type": "text",
                  "description": "Price (required)"
                },
                {
                  "key": "offerPrice",
                  "value": "9.99",
                  "type": "text",
                  "description": "Offer price (optional)"
                },
                {
                  "key": "featured",
                  "value": "true",
                  "type": "text",
                  "description": "Featured flag (optional, true/false)"
                },
                {
                  "key": "tags",
                  "value": "vegetarian,gluten-free",
                  "type": "text",
                  "description": "Comma-separated tags (optional)"
                },
                {
                  "key": "position",
                  "value": "1",
                  "type": "text",
                  "description": "Position in category (optional)"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "Image file (JPEG, PNG, or WebP, max 5MB). Will be automatically processed and uploaded to GCP Storage."
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/restaurants/:restaurantId/dishes/with-image",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "restaurants", ":restaurantId", "dishes", "with-image"],
              "variable": [
                {
                  "key": "restaurantId",
                  "value": "{{restaurantId}}",
                  "description": "UUID of the restaurant"
                }
              ]
            },
            "description": "Creates a new dish with image upload. The image will be automatically processed (resized to thumbnail, medium, and large variants) and uploaded to GCP Storage. The large variant URL will be saved as the dish imageUrl. categoryId, name, and price are required. Image is optional but recommended.\n\n**Tip:** After creating a dish, copy its `id` from the response and set it as the `dishId` collection variable for easier testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('dishId', json.id);",
                  "        console.log('Dish ID saved to collection variable:', json.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
