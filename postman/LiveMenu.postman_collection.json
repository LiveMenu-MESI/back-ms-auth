    {
      "name": "Image Upload (CU-05)",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "Image file (JPEG, PNG, or WebP). Max size: 5MB. The image will be processed and stored in GCP Storage with variants: thumbnail (150x150), medium (400x400), and large (800x800)."
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/images/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "images", "upload"]
            },
            "description": "Uploads and processes an image. Accepts multipart/form-data with field name 'image'. The backend will:\n- Validate file type (JPEG, PNG, WebP) and size (max 5MB)\n- Resize to thumbnail (150x150, 80% quality), medium (400x400, 85% quality), and large (800x800, 90% quality)\n- Optimize and convert to WebP (with JPEG fallback)\n- Upload to GCP Storage\n- Return URLs for all variants\n\nResponse includes:\n- originalUrl: URL for original image (or large if original is small)\n- thumbnailUrl: URL for 150x150 variant\n- mediumUrl: URL for 400x400 variant\n- largeUrl: URL for 800x800 variant\n- metadata: Information about the processed image\n\nRequires authentication via Bearer token."
          }
        },
        {
          "name": "Get Image (Redirect)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/images/:variant/:filename",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "images", ":variant", ":filename"],
              "variable": [
                {
                  "key": "variant",
                  "value": "large",
                  "description": "Image variant: original, thumbnail, medium, or large"
                },
                {
                  "key": "filename",
                  "value": "image-uuid.webp",
                  "description": "Image filename (UUID with extension)"
                }
              ]
            },
            "description": "Redirects to the public GCP Storage URL for the image. This endpoint is kept for backward compatibility. Images are served directly from GCP Storage via public URLs returned in the upload response."
          }
        },
        {
          "name": "Delete Image",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/images/:filename",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "images", ":filename"],
              "variable": [
                {
                  "key": "filename",
                  "value": "image-uuid.webp",
                  "description": "Image filename (UUID with extension). Deletes all variants (original, thumbnail, medium, large)."
                }
              ]
            },
            "description": "Deletes an image and all its variants (original, thumbnail, medium, large) from GCP Storage. Requires authentication."
          }
        }
      ],
      "description": "Image upload and management endpoints (CU-05). Upload endpoint requires authentication via Bearer token. Images are processed, optimized, and stored in GCP Storage with multiple size variants."
    },
